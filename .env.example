# Database
POSTGRES_USER=dryclean
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=dryclean_content

# RabbitMQ
RABBITMQ_USER=dryclean
RABBITMQ_PASS=change_me_strong_password

# SSL
CERTBOT_EMAIL=admin@da-dryclean.ru

# Frontend
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_CONTENT_API_URL=/api/content
NEXT_PUBLIC_TRACKING_API_URL=http://localhost:8020

# Tracking Service
TRACKING_DATABASE_URL=postgresql+asyncpg://dryclean:change_me_strong_password@postgres:5432/dryclean_content
TRACKING_DATABASE_URL_SYNC=postgresql+psycopg2://dryclean:change_me_strong_password@postgres:5432/dryclean_content
TRACKING_RATE_LIMIT=100
TRACKING_CORS_ORIGINS=["*"]

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_PROXY_URL=

# VPS deploy (for CI/CD — set in GitHub Secrets, not here)
# VPS_HOST=
# VPS_USER=
# VPS_PORT=22
# SSH_PRIVATE_KEY=
# GITHUB_TOKEN=
